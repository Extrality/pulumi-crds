{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "index.ts",
        "postgresql/index.ts",
        "postgresql/v1/backup.ts",
        "postgresql/v1/backupList.ts",
        "postgresql/v1/backupPatch.ts",
        "postgresql/v1/cluster.ts",
        "postgresql/v1/clusterImageCatalog.ts",
        "postgresql/v1/clusterImageCatalogList.ts",
        "postgresql/v1/clusterImageCatalogPatch.ts",
        "postgresql/v1/clusterList.ts",
        "postgresql/v1/clusterPatch.ts",
        "postgresql/v1/database.ts",
        "postgresql/v1/databaseList.ts",
        "postgresql/v1/databasePatch.ts",
        "postgresql/v1/databaseRole.ts",
        "postgresql/v1/databaseRoleList.ts",
        "postgresql/v1/databaseRolePatch.ts",
        "postgresql/v1/failoverQuorum.ts",
        "postgresql/v1/failoverQuorumList.ts",
        "postgresql/v1/failoverQuorumPatch.ts",
        "postgresql/v1/imageCatalog.ts",
        "postgresql/v1/imageCatalogList.ts",
        "postgresql/v1/imageCatalogPatch.ts",
        "postgresql/v1/index.ts",
        "postgresql/v1/pooler.ts",
        "postgresql/v1/poolerList.ts",
        "postgresql/v1/poolerPatch.ts",
        "postgresql/v1/publication.ts",
        "postgresql/v1/publicationList.ts",
        "postgresql/v1/publicationPatch.ts",
        "postgresql/v1/scheduledBackup.ts",
        "postgresql/v1/scheduledBackupList.ts",
        "postgresql/v1/scheduledBackupPatch.ts",
        "postgresql/v1/subscription.ts",
        "postgresql/v1/subscriptionList.ts",
        "postgresql/v1/subscriptionPatch.ts",
        "provider.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
