{
    "compilerOptions": {
        // Output
        "outDir": "bin",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "stripInternal": true,
        // Environment
        "target": "ES2022",
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "moduleDetection": "force",
        "types": ["node"],
        // Type Checking
        "strict": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitReturns": true,
        "skipLibCheck": true
    },
    "files": [
        "actions/index.ts",
        "actions/v1alpha1/autoscalingListener.ts",
        "actions/v1alpha1/autoscalingListenerList.ts",
        "actions/v1alpha1/autoscalingListenerPatch.ts",
        "actions/v1alpha1/autoscalingRunnerSet.ts",
        "actions/v1alpha1/autoscalingRunnerSetList.ts",
        "actions/v1alpha1/autoscalingRunnerSetPatch.ts",
        "actions/v1alpha1/ephemeralRunner.ts",
        "actions/v1alpha1/ephemeralRunnerList.ts",
        "actions/v1alpha1/ephemeralRunnerPatch.ts",
        "actions/v1alpha1/ephemeralRunnerSet.ts",
        "actions/v1alpha1/ephemeralRunnerSetList.ts",
        "actions/v1alpha1/ephemeralRunnerSetPatch.ts",
        "actions/v1alpha1/index.ts",
        "index.ts",
        "provider.ts",
        "types/index.ts",
        "types/input.ts",
        "types/output.ts",
        "utilities.ts"
    ]
}
